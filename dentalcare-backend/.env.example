# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/dental_saas"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 random bytes (64 hex chars). No fallback — app will refuse to start if missing.
JWT_SECRET="REPLACE_WITH_64_CHAR_HEX_SECRET"

# Short-lived access token (15m recommended for production)
JWT_EXPIRES_IN="15m"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Must be set in production — app will refuse to start without it
FRONTEND_URL="http://localhost:3000"

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-REPLACE_WITH_YOUR_KEY"

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_KEY"
# Get from https://dashboard.stripe.com/webhooks after creating a webhook endpoint
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET"
